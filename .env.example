# Environment configuration for StaticJS
# Copy this file to .env and modify values according to your needs

# ===========================================
# NETWORK CONFIGURATION
# ===========================================

# Server host binding (127.0.0.1 = localhost only, recommended for security)
HOST=127.0.0.1

# Server listening port
PORT=3456

# ===========================================
# SECURITY
# ===========================================

# Security token for /revalidate endpoint
# Generate with: openssl rand -hex 32
REVALIDATE_TOKEN=

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# ENVIRONMENT
# ===========================================

# Runtime environment (development/production)
NODE_ENV=development