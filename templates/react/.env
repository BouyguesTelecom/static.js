# Environment variables for the React template
# Variables prefixed with VITE_ are automatically exposed to the client-side code
VITE_APP_TITLE="My Static React App"
VITE_API_URL="https://api.example.com"

# Non-VITE_ prefixed variables are only available on the server-side
# but can be explicitly exposed in vite.config.ts
TEST="NINJA"
DATABASE_URL="postgresql://localhost:5432/mydb"

# ===========================================
# STATICJS SERVER CONFIGURATION
# ===========================================

# Server host binding (127.0.0.1 = localhost only, recommended for security)
HOST=127.0.0.1

# Server listening port
PORT=3456

# Runtime environment (development/production)
NODE_ENV=development

# ===========================================
# SECURITY
# ===========================================

# Security token for /revalidate endpoint
# Generate with: openssl rand -hex 32
REVALIDATE_TOKEN=

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

